+#!/usr/bin/env python3
+"""Test script to verify echo_via_pager works with generators."""
+import time
+import click
+import sys
+
+def count():
+    """Generator that yields items with delay, simulating the original issue."""
+    for i in range(5):
+        time.sleep(0.5)
+        yield f"count {i}\n"
+
+def count_no_sleep():
+    """Generator that yields items without delay."""
+    for i in range(5):
+        yield f"count {i}\n"
+
+if __name__ == "__main__":
+    if len(sys.argv) > 1 and sys.argv[1] == "sleep":
+        print("Testing with delayed generator (should show output as it comes)...")
+        click.echo_via_pager(count())
+    else:
+        print("Testing with immediate generator...")
+        click.echo_via_pager(count_no_sleep())
