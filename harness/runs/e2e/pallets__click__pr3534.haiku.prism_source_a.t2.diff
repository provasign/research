+#!/usr/bin/env python3
+"""Test that echo_via_pager works correctly with generators that have delays."""
+
+import time
+import click
+import sys
+
+def count_generator():
+    """Generator that yields items with delays, simulating the issue."""
+    for i in range(3):
+        time.sleep(0.1)  # Small delay to simulate slow generator
+        yield f"Item {i}\n"
+
+if __name__ == "__main__":
+    # This test demonstrates that the fix allows output to be displayed
+    # as items are yielded, not all at once after all items are generated
+    print("Testing echo_via_pager with a generator that has delays...")
+    print("Each item should appear immediately as it's yielded:")
+    print()
+
+    click.echo_via_pager(count_generator())
+
+    print("Test completed!")
