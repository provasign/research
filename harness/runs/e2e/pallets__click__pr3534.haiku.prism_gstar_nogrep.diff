@@ -0,0 +1,46 @@
+"""Verify that flush is being called after each write."""
+import click
+from unittest.mock import patch, MagicMock
+
+def test_pager_flush():
+    """Verify that pager.flush() is called after each write."""
+    writes = []
+    flushes = []
+
+    def mock_write(text):
+        writes.append(text)
+        return len(text)
+
+    def mock_flush():
+        flushes.append(True)
+
+    # Create a generator that yields a few times
+    def gen():
+        yield "line1\n"
+        yield "line2\n"
+        yield "line3\n"
+
+    # Patch get_pager_file to return our mock stream
+    mock_stream = MagicMock()
+    mock_stream.write = mock_write
+    mock_stream.flush = mock_flush
+    mock_stream.__enter__ = MagicMock(return_value=mock_stream)
+    mock_stream.__exit__ = MagicMock(return_value=False)
+
+    with patch('click.termui.get_pager_file', return_value=mock_stream):
+        click.echo_via_pager(gen())
+
+    # Verify we have writes
+    print(f"Writes: {writes}")
+    print(f"Flushes count: {len(flushes)}")
+
+    # We should have 4 writes: "line1\n", "line2\n", "line3\n", "\n"
+    assert len(writes) == 4, f"Expected 4 writes, got {len(writes)}"
+
+    # We should have at least 4 flushes (one after each write)
+    assert len(flushes) >= 4, f"Expected at least 4 flushes, got {len(flushes)}"
+
+    print("✓ Flush is being called after each write!")
+
+if __name__ == "__main__":
+    test_pager_flush()
