+import click
+import os
+import time
+
+def _generator():
+    for i in range(10000):
+        time.sleep(0.01)
+        yield f"{i+1:07}\n"
+
+@click.command()
+def main():
+    os.environ.setdefault("LESS", "-XFR")
+    click.echo_via_pager(_generator())
+
+if __name__ == "__main__":
+    main()
