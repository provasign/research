+#!/usr/bin/env python3
+
+import io
+import sys
+import os
+
+# Add the src directory to the path so we can import click
+sys.path.insert(0, os.path.join(os.path.dirname(__file__), 'src'))
+
+import click
+
+def test_empty_bytes_echo():
+    """Test that echo works with empty bytes and nl=True"""
+    print("Testing echo with empty bytes and nl=True...")
+    try:
+        output = io.BytesIO()
+        click.echo(b'', output, nl=True)
+        print("SUCCESS: No TypeError raised")
+        print(f"Output content: {output.getvalue()}")
+        assert output.getvalue() == b'\n'
+        print("✓ Empty bytes test passed")
+    except Exception as e:
+        print(f"ERROR: {type(e).__name__}: {e}")
+        raise
+
+def test_empty_bytearray_echo():
+    """Test that echo works with empty bytearray and nl=True"""
+    print("Testing echo with empty bytearray and nl=True...")
+    try:
+        output = io.BytesIO()
+        click.echo(bytearray(), output, nl=True)
+        print("SUCCESS: No TypeError raised")
+        print(f"Output content: {output.getvalue()}")
+        assert output.getvalue() == b'\n'
+        print("✓ Empty bytearray test passed")
+    except Exception as e:
+        print(f"ERROR: {type(e).__name__}: {e}")
+        raise
+
+def test_normal_echo():
+    """Test that normal echo still works"""
+    print("Testing normal echo functionality...")
+    try:
+        output = io.StringIO()
+        click.echo("hello", output, nl=True)
+        print("SUCCESS: Normal echo works")
+        print(f"Output content: {output.getvalue()}")
+        assert output.getvalue() == "hello\n"
+        print("✓ Normal echo test passed")
+    except Exception as e:
+        print(f"ERROR: {type(e).__name__}: {e}")
+        raise
+
+def test_empty_string_echo():
+    """Test that empty string echo works"""
+    print("Testing echo with empty string...")
+    try:
+        output = io.StringIO()
+        click.echo("", output, nl=True)
+        print("SUCCESS: Empty string echo works")
+        print(f"Output content: {output.getvalue()}")
+        assert output.getvalue() == "\n"
+        print("✓ Empty string test passed")
+    except Exception as e:
+        print(f"ERROR: {type(e).__name__}: {e}")
+        raise
+
+if __name__ == "__main__":
+    print("Running comprehensive echo tests...")
+    test_empty_bytes_echo()
+    test_empty_bytearray_echo()
+    test_normal_echo()
+    test_empty_string_echo()
+    print("\n✓ All tests passed!")
