+def test_help_option_automatic_conflict_resolution(runner):
+    """Test that the help option automatically resolves conflicts with arguments.
+
+    When a parameter is named 'help' (with or without dashes), the automatic
+    help option should be disabled to avoid conflicts.
+    """
+    # Test: argument named 'help' should disable the help option
+    @click.command()
+    @click.argument("help")
+    def cmd_arg_help(help):
+        click.echo(f"help={help}")
+
+    # The argument accepts a value
+    result = runner.invoke(cmd_arg_help, ["value"])
+    assert result.exit_code == 0
+    assert result.output == "help=value\n"
+
+    # --help is treated as the argument value (not the help flag)
+    result = runner.invoke(cmd_arg_help, ["--help"])
+    assert result.exit_code == 2
+
+    # Test: argument named differently should allow help
+    @click.command()
+    @click.argument("something")
+    def cmd_arg_other(something):
+        click.echo(f"something={something}")
+
+    # The --help flag works
+    result = runner.invoke(cmd_arg_other, ["--help"])
+    assert result.exit_code == 0
+    assert "Usage:" in result.output
+
+    # Test: option named '--help' should disable the help option
+    @click.command()
+    @click.option("--help", default="default")
+    def cmd_opt_help(help):
+        click.echo(f"help={help}")
+
+    # The option accepts a value
+    result = runner.invoke(cmd_opt_help, ["--help", "value"])
+    assert result.exit_code == 0
+    assert result.output == "help=value\n"
+
+    # Without the value, it uses the default
+    result = runner.invoke(cmd_opt_help, [])
+    assert result.exit_code == 0
+    assert result.output == "help=default\n"
+
+
+def test_get_help_option_names_with_conflicts(runner):
+    """Test get_help_option_names correctly handles parameter name conflicts."""
+    # Test with argument named 'help'
+    @click.command()
+    @click.argument("help")
+    def cmd1(help):
+        pass
+
+    ctx = click.Context(cmd1)
+    assert cmd1.get_help_option_names(ctx) == []
+
+    # Test with argument named 'something_else'
+    @click.command()
+    @click.argument("something_else")
+    def cmd2(something_else):
+        pass
+
+    ctx = click.Context(cmd2)
+    assert cmd2.get_help_option_names(ctx) == ["--help"]
+
+    # Test with option '--help'
+    @click.command()
+    @click.option("--help", default="value")
+    def cmd3(help):
+        pass
+
+    ctx = click.Context(cmd3)
+    assert cmd3.get_help_option_names(ctx) == []
