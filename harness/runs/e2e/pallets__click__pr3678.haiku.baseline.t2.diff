@@ -741,3 +741,44 @@ def test_argument_custom_class_can_override_type_cast_value_and_never_sees_unset
     result = runner.invoke(cmd, pass_argv)
     assert not result.exception
     assert result.exit_code == 0
+
+
+def test_argument_named_help(runner):
+    """Test that an argument named 'help' doesn't interfere with auto-generated help option.
+
+    When a command has an argument named 'help', the automatic '--help' option
+    should not be added to prevent naming conflicts. Positional arguments should
+    work correctly.
+    """
+    @click.command()
+    @click.argument("help")
+    def cmd(help):
+        click.echo(f"help={help}")
+
+    # Test positional argument works
+    result = runner.invoke(cmd, ["value"])
+    assert result.exit_code == 0
+    assert "help=value" in result.output
+
+    # Test --help is not available (since there's a parameter named 'help')
+    result = runner.invoke(cmd, ["--help"])
+    assert result.exit_code == 2
+    assert "No such option '--help'" in result.output
+
+
+def test_option_named_help(runner):
+    """Test that an option named '--help' prevents auto-generated help option."""
+    @click.command()
+    @click.option("--help", default="default_value")
+    def cmd(help):
+        click.echo(f"help={help}")
+
+    # Test the custom --help option works
+    result = runner.invoke(cmd, ["--help", "custom_value"])
+    assert result.exit_code == 0
+    assert "help=custom_value" in result.output
+
+    # Test --help without value (should fail since it's a required option)
+    result = runner.invoke(cmd, ["--help"])
+    assert result.exit_code == 2
+    assert "Option '--help' requires an argument" in result.output
