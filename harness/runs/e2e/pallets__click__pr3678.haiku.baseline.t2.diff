+def test_help_option_with_conflicting_params(runner):
+    """Help option should not be added if a param has the same name."""
+
+    # Test 1: Argument named 'help' should conflict with help option
+    @click.command()
+    @click.argument("help")
+    def cmd1(help):
+        click.echo(f"help={help}")
+
+    # Should work with a value
+    result = runner.invoke(cmd1, ["value"])
+    assert result.exit_code == 0
+    assert result.output == "help=value\n"
+
+    # Should show error about missing argument, not about --help
+    result = runner.invoke(cmd1, [])
+    assert result.exit_code == 2
+    assert "Missing argument" in result.output
+    assert "HELP" in result.output
+
+    # Test 2: Option '--help' should conflict with default help option
+    @click.command()
+    @click.option("--help", default="default")
+    def cmd2(help):
+        click.echo(f"help={help}")
+
+    # Should work with default
+    result = runner.invoke(cmd2, [])
+    assert result.exit_code == 0
+    assert "help=default" in result.output
+
+    # Should work with custom value
+    result = runner.invoke(cmd2, ["--help", "custom"])
+    assert result.exit_code == 0
+    assert "help=custom" in result.output
+
+    # Test 3: Normal argument should still have --help option
+    @click.command()
+    @click.argument("name")
+    def cmd3(name):
+        click.echo(f"name={name}")
+
+    result = runner.invoke(cmd3, ["--help"])
+    assert result.exit_code == 0
+    assert "Usage:" in result.output
+    assert "Show this message" in result.output
+
+
