+#!/usr/bin/env python3
+"""Test that echo_via_pager streams output from generators correctly."""
+import time
+import click
+import sys
+
+def count_generator():
+    """Simulate the user's reported issue - a generator that yields slowly."""
+    for i in range(5):
+        time.sleep(0.5)
+        yield f"\ncount {i}"
+
+if __name__ == "__main__":
+    # Use cat as the pager to see output in real-time
+    import os
+    os.environ["PAGER"] = "cat"
+
+    print("Testing generator streaming with echo_via_pager...", file=sys.stderr)
+    print("Output should appear progressively, not all at once:", file=sys.stderr)
+
+    click.echo_via_pager(count_generator())
