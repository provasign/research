@@ -1146,6 +1146,16 @@ class Command:
         for param in self.params:
             all_names.difference_update(param.opts)
             all_names.difference_update(param.secondary_opts)
+            # Also remove help option names that would conflict with existing
+            # parameter names. For example, if there's an argument named 'help',
+            # we shouldn't create a help option '--help' since it would derive
+            # to the name 'help' which would conflict.
+            for help_name in list(all_names):
+                # Derive what the parameter name would be from this option name
+                _prefix, name = _split_opt(help_name)
+                param_name = name.replace("-", "_").lower()
+                if param_name == param.name:
+                    all_names.discard(help_name)
         return list(all_names)
 
