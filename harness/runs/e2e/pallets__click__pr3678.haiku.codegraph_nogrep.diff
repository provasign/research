diff --git a/tests/test_arguments.py b/tests/test_arguments.py
index f4b4523..8e2cc55 100644
--- a/tests/test_arguments.py
+++ b/tests/test_arguments.py
@@ -741,3 +741,44 @@ def test_argument_custom_class_can_override_type_cast_value_and_never_sees_unset
     result = runner.invoke(cmd, pass_argv)
     assert not result.exception
     assert result.exit_code == 0
+
+
+def test_argument_named_help(runner):
+    """When an argument is named 'help', the automatic --help option is not added."""
+    @click.command()
+    @click.argument("help")
+    def cmd(help):
+        click.echo(f"help={help}")
+
+    # The argument should accept values without conflict
+    result = runner.invoke(cmd, ["test_value"])
+    assert result.exit_code == 0
+    assert "help=test_value" in result.output
+
+    # The --help option should not be available since there's a conflict
+    result = runner.invoke(cmd, ["--help"])
+    assert result.exit_code == 2
+    assert "No such option '--help'" in result.output
+
+
+def test_option_named_help(runner):
+    """When an option is named '--help', it overrides the automatic help option."""
+    @click.command()
+    @click.option("--help", default="default_help")
+    def cmd(help):
+        click.echo(f"help={help}")
+
+    # The option should work with its default value
+    result = runner.invoke(cmd, [])
+    assert result.exit_code == 0
+    assert "help=default_help" in result.output
+
+    # The user-defined --help option should require a value
+    result = runner.invoke(cmd, ["--help"])
+    assert result.exit_code == 2
+    assert "Option '--help' requires an argument" in result.output
+
+    # The option should work with a provided value
+    result = runner.invoke(cmd, ["--help", "custom_value"])
+    assert result.exit_code == 0
+    assert "help=custom_value" in result.output
