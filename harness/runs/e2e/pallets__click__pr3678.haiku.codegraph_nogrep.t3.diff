+def test_help_option_names_conflict_with_argument(runner):
+    """When an argument is named 'help', the --help option should not be added."""
+    @click.command()
+    @click.argument("help")
+    def cli(help):
+        click.echo(help)
+
+    # The argument should work
+    result = runner.invoke(cli, ["test_value"])
+    assert result.exit_code == 0
+    assert "test_value" in result.output
+
+    # --help should not exist since it conflicts with the argument
+    result = runner.invoke(cli, ["--help"])
+    assert result.exit_code != 0
+    assert "No such option" in result.output or "Error" in result.output
+
+
+def test_help_option_names_conflict_with_option(runner):
+    """When an option is named '--help', the automatic help option should not be added."""
+    @click.command()
+    @click.option("--help", default="default")
+    def cli(help):
+        click.echo(help)
+
+    # The option should work normally
+    result = runner.invoke(cli, [])
+    assert result.exit_code == 0
+    assert "default" in result.output
+
+    # --help should work as the user's option
+    result = runner.invoke(cli, ["--help", "custom"])
+    assert result.exit_code == 0
+    assert "custom" in result.output
+
+
+def test_help_option_names_conflict_custom_name(runner):
+    """When custom help option name is configured, conflicts should still be resolved."""
+    @click.command(context_settings={"help_option_names": ["--ayuda"]})
+    @click.argument("ayuda")
+    def cli(ayuda):
+        click.echo(ayuda)
+
+    # The argument should work
+    result = runner.invoke(cli, ["test_value"])
+    assert result.exit_code == 0
+    assert "test_value" in result.output
+
+    # --ayuda should not exist since it conflicts with the argument
+    result = runner.invoke(cli, ["--ayuda"])
+    assert result.exit_code != 0
+    assert "No such option" in result.output or "Error" in result.output
+
+
