+import click
+from click.testing import CliRunner
+
+# Scenario 1: This works
+@click.command()
+@click.argument('helps')
+def this_works(helps):
+    click.echo(f"Argument value: {helps}")
+
+# Scenario 2: This should work with the fix
+@click.command()
+@click.argument('help')
+def this_does_not_work(help):
+    click.echo(f"Argument value: {help}")
+
+# Scenario 3: This should work with the fix
+@click.command()
+@click.option('--help', default='this_2')
+def this_does_not_work_also(help='this_2'):
+    click.echo(f"Option value: {help}")
+
+runner = CliRunner()
+
+print("=" * 60)
+print("SCENARIO 1: Argument named 'helps' (should always work)")
+print("=" * 60)
+
+print("\n1a. With --help flag:")
+result = runner.invoke(this_works, ['--help'])
+print(f"Exit code: {result.exit_code}")
+print(result.output)
+
+print("1b. With positional value 'test':")
+result = runner.invoke(this_works, ['test'])
+print(f"Exit code: {result.exit_code}")
+print(result.output)
+
+print("\n" + "=" * 60)
+print("SCENARIO 2: Argument named 'help' (should work with fix)")
+print("=" * 60)
+
+print("\n2a. With --help flag:")
+result = runner.invoke(this_does_not_work, ['--help'])
+print(f"Exit code: {result.exit_code}")
+print(result.output)
+
+print("2b. With positional value 'test':")
+result = runner.invoke(this_does_not_work, ['test'])
+print(f"Exit code: {result.exit_code}")
+print(result.output)
+
+print("\n" + "=" * 60)
+print("SCENARIO 3: Option named '--help' (should work with fix)")
+print("=" * 60)
+
+print("\n3a. With --help flag and value:")
+result = runner.invoke(this_does_not_work_also, ['--help', 'myvalue'])
+print(f"Exit code: {result.exit_code}")
+print(result.output)
+
+print("3b. With no arguments (should use default):")
+result = runner.invoke(this_does_not_work_also, [])
+print(f"Exit code: {result.exit_code}")
+print(result.output)
